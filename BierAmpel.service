[Unit]
Description=Ampelkontrolle und MQTT Broadcast.
After=network.target mosquitto.service
Wants=mosquitto.service

[Service]
Type=exec
ExecStart=/opt/BierAmpel/BierAmpel --serial /dev/ttyUSB0 --user user --pass password
Restart=on-failure
RestartSec=5
User=root
Group=root

[Install]
WantedBy=multi-user.target